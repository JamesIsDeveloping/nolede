# Copy to .env and fill in your values

# Required
OPENAI_API_KEY=sk-...

# MongoDB — when using docker-compose this is overridden automatically.
# For Railway / Atlas use a full connection string instead.
MONGODB_URI=mongodb://mongo:27017/nolede

# Optional — defaults shown
PORT=3000

# Semicolon-separated cron expressions (UTC).
# Defaults approximate 6 am, noon, and 3:30 pm NZT (UTC+12).
CRON_SCHEDULE=0 18 * * *;0 0 * * *;30 3 * * *
